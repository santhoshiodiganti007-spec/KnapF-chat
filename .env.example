# Database Connection (PostgreSQL - Vercel Postgres / Neon / Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/novachat?schema=public"

# Auth Secrets
JWT_SECRET="super-secret-jwt-token-change-in-production"
NEXTAUTH_SECRET="super-secret-nextauth-token"

# Server Port (Standalone)
PORT=4000

# Public Frontend API URLs (Used by Vercel web & admin apps)
NEXT_PUBLIC_API_URL="https://nova-chat-server.vercel.app/api"
NEXT_PUBLIC_ADMIN_URL="https://nova-chat-admin.vercel.app"
NEXT_PUBLIC_WEB_URL="https://nova-chat-web.vercel.app"
